{
  "topic": "array",
  "name": "Minimize the Heights II",
  "platform": "GFG",
  "difficulty": "Medium",
  "statement": "Given heights of towers and integer k. For each tower either increase or decrease height by k exactly once. Minimize the difference between tallest and shortest tower after modification. Resulting heights cannot be negative.",
  "examples": [
    {
      "input": {
        "k": 2,
        "arr": [
          1,
          5,
          8,
          10
        ]
      },
      "output": 5
    },
    {
      "input": {
        "k": 3,
        "arr": [
          3,
          9,
          12,
          16,
          20
        ]
      },
      "output": 11
    }
  ],
  "constraints": {
    "k": "1 <= k <= 10000000",
    "n": "1 <= n <= 100000",
    "arr_value": "1 <= arr[i] <= 10000000"
  },
