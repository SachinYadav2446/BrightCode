{
  "topic": "array",
  "name": "Count Inversions",
  "platform": "GFG",
  "difficulty": "Hard",
  "statement": "Given an array of integers. Count the number of inversions in the array. An inversion is a pair (i, j) such that i < j and arr[i] > arr[j].",
  "examples": [
