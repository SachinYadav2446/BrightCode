# ─── BrightCode Server — Environment Variables ──────────────────────────────
# Copy this file to .env for local development.
# For production, set these in the Render dashboard (Web Service → Environment).

# Neon PostgreSQL connection string (required)
DB_CONNECTION_STRING=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# JWT signing secret — use a strong random string in production
JWT_SECRET=brightcode_secret_key_123

# Deployed frontend URL for CORS (no trailing slash)
# Local dev: leave blank or set to http://localhost:5173
# Production: https://brightcode-client.onrender.com
FRONTEND_URL=http://localhost:5173

# Nodemailer / Gmail SMTP credentials for OTP emails
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Server port (Render sets this automatically — do not override in production)
# PORT=5051
