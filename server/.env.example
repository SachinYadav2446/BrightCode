# ─── BrightCode Server — Environment Variables ──────────────────────────────
# Copy this file to .env for local development.
# For production, set these in the Render dashboard (Web Service → Environment).

# Neon PostgreSQL connection string (required)
DB_CONNECTION_STRING=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# JWT signing secret — use a strong random string in production
JWT_SECRET=brightcode_secret_key_123

# Deployed frontend URL for CORS (no trailing slash)
# Local dev: leave blank or set to http://localhost:5173
# Production: https://brightcode-client.onrender.com
FRONTEND_URL=http://localhost:5173

# Resend API Key for email (works on Render free tier - recommended for production)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Google OAuth credentials for Google Sign-In
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5051/auth/google/callback

# Nodemailer / Gmail SMTP credentials for OTP emails (fallback for local dev only)
# Note: SMTP is blocked on Render free tier, use RESEND_API_KEY instead
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Server port (Render sets this automatically — do not override in production)
# PORT=5051
