# ─── BrightCode Server — Environment Variables ──────────────────────────────
# Copy this file to .env for local development.
# For production, set these in the Render dashboard (Web Service → Environment).

# Neon PostgreSQL connection string (required)
DB_CONNECTION_STRING=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# JWT signing secret — use a strong random string in production
JWT_SECRET=brightcode_secret_key_123

# Deployed frontend URL for CORS (no trailing slash)
# Local dev: leave blank or set to http://localhost:5173
# Production: https://brightcode-client.onrender.com
FRONTEND_URL=http://localhost:5173

# Nodemailer / SMTP credentials for OTP emails (required for email functionality)
# Options: Use service (e.g., 'gmail') OR host/port/secure
# For Gmail: Get your app password from: https://myaccount.google.com/apppasswords
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=your-sendgrid-api-key
SMTP_SERVICE=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=your-verified-sender-email@example.com

# Server port (Render sets this automatically — do not override in production)
# PORT=5051

# GitHub OAuth — required for one-click clone/push in workspace (optional for PAT-only)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Public backend URL for OAuth callback (local dev)
BACKEND_URL=http://localhost:5051

# Pal Chatbot Configuration:
# 100% API-FREE! No API keys needed!
# Just add/remove knowledge to brightcode_knowledge.json to expand Pal's knowledge!
