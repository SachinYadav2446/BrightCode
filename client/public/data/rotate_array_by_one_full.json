{
  "topic": "array",
  "name": "Rotate Array by One",
  "platform": "GFG",
  "difficulty": "Basic",
  "statement": "Given an array arr, rotate the array by one position in clockwise direction.",
  "examples": [
    {
      "input": [
        1,
        2,
        3,
        4,
        5
      ],
      "output": [
        5,
        1,
        2,
        3,
        4
      ]
    },
    {
      "input": [
        9,
        8,
        7,
        6,
        4,
        2,
        1,
        3
      ],
      "output": [
        3,
        9,
        8,
        7,
        6,
        4,
        2,
        1
      ]
    }
  ],
  "constraints": {
    "arr_size": "1 <= arr.size() <= 100000",
    "arr_value": "0 <= arr[i] <= 100000"
  },
