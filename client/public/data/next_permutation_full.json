{
  "topic": "array",
  "name": "Next Permutation",
  "platform": "LeetCode",
  "difficulty": "Medium",
  "statement": "Implement next permutation, which rearranges numbers into the lexicographically next greater permutation. If such arrangement is not possible, rearrange into the lowest possible order.",
