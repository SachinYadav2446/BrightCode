        [
          15,
          18
        ]
      ],
      "output": [
        [
          1,
          6
        ],
        [
          8,
          10
        ],
        [
          15,
          18
        ]
      ]
    },
    {
      "input": [
        [
          1,
          4
        ],
        [
          4,
          5
        ]
      ],
      "output": [
        [
          1,
          5
        ]
      ]
    }
  ],
  "constraints": {
    "intervals": "1 <= intervals.length <= 100000",
    "values": "0 <= start <= end <= 100000"
