{
  "topic": "array",
  "name": "Merge Intervals",
  "platform": "LeetCode",
  "difficulty": "Medium",
  "statement": "Given an array of intervals where intervals[i] = [start, end], merge all overlapping intervals and return an array of the non-overlapping intervals that cover all intervals in the input.",
  "examples": [
    {
      "input": [
        [
          1,
          3
        ],
        [
          2,
          6
        ],
        [
          8,
          10
