# ─── BrightCode Client — Environment Variables ──────────────────────────────
# Copy this file to .env.local for local development.
# For production, set these in the Render dashboard (Static Site → Environment).

# Backend API & Socket.IO URL
# Local dev:       http://localhost:5051
# Production:      https://brightcode-server.onrender.com  (your Render backend URL)
VITE_BACKEND_URL=http://localhost:5051
